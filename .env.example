# Gemini API Key (Required for audio transcription)
GEMINI_API_KEY=

# Google Picker API Key (Required for selecting Google Docs)
VITE_GOOGLE_PICKER_API_KEY=

# Production URL used by backend-generated links
VERCEL_PRODUCTION_URL=https://evolucaoclinica.app.br

# Lifecycle failure alerting (optional; defaults to 3 failures and 60 minutes)
# LIFECYCLE_FAILURE_ALERT_THRESHOLD=3
# LIFECYCLE_FAILURE_ALERT_COOLDOWN_MINUTES=60

# Firebase Configuration (Optional if using firebase-applet-config.json)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=

# Firebase Admin SDK (JSON completo da conta de serviço, em uma única linha)
# FIREBASE_SERVICE_ACCOUNT_JSON=
